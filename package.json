{
  "name": "spica-arena-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:local": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "check:env": "node scripts/check-env.js",
    "check:prod-data": "node scripts/check-production-data-guard.js",
    "supabase:storage": "node scripts/setup-supabase-storage.js",
    "check:db": "tsx scripts/check-db.ts",
    "zone-os:setup": "node scripts/setup-zone-os-runtime.js",
    "zone-os:setup:db": "node scripts/setup-zone-os-runtime.js --apply-db",
    "zone-os:db:check": "node scripts/zone-os-db.js check",
    "zone-os:db:setup": "node scripts/zone-os-db.js setup",
    "zone-os:repair": "node scripts/setup-zone-os-runtime.js && node scripts/zone-os-db.js repair",
    "zone-os:dev": "next dev --hostname 0.0.0.0",
    "zone-os:desktop:dev": "node zone-os/desktop/launch.js",
    "zone-os:desktop:build": "node scripts/build-zone-os-desktop.js",
    "zone-os:package": "node scripts/build-zone-os-desktop.js",
    "zone-os:installer": "node scripts/build-zone-os-desktop.js",
    "db:reset-demo": "prisma migrate reset --force && npm run db:seed:dev",
    "db:seed:prod": "tsx prisma/seed.prod.ts",
    "db:seed:dev": "tsx prisma/seed.dev.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "realtime": "node scripts/free-port.js 4001 && tsx server/realtime.ts",
    "pc-agent": "tsx pc-agent/agent.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.prod.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "next": "^15.3.8",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "ws": "^8.20.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.17.10",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.20",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.3.8",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
