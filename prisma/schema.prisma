generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  player
  zone_owner
  manager
  admin
}

enum PCStatus {
  available
  in_use
  offline
}

enum ZoneStatus {
  pending
  active
  rejected
  suspended
}

enum PCCategory {
  standard
  premium
  vip
}

enum SessionStatus {
  active
  completed
}

enum TransactionType {
  buy
  spend
  reward
  withdraw
}

enum WithdrawalStatus {
  pending
  approved
  rejected
}

enum SettlementStatus {
  pending
  approved
  paid
}

enum FriendshipStatus {
  pending
  accepted
  blocked
}

enum NotificationType {
  session
  achievement
  friend
  zone
  balance
  system
}

enum ListingRequestStatus {
  pending
  contacted
  approved
  rejected
}

enum PairingRequestStatus {
  pending
  approved
  rejected
  expired
}

enum AuditAction {
  signup
  login
  logout
  forgot_password
  verify_email
  update_profile
  create_zone
  update_zone
  buy_spica
  start_session
  add_time
  end_session
  create_settlement
  request_withdrawal
  approve_withdrawal
  reject_withdrawal
  pc_heartbeat
  pc_status
  pc_pairing_request
  pc_pairing_approved
  pc_pairing_rejected
  pc_manual_override
}

model User {
  id             String        @id @default(cuid())
  name           String
  email          String        @unique
  username       String        @unique
  avatar         String?
  banner         String?
  bio            String?
  favoriteGames  String[]      @default([])
  password       String
  role           UserRole      @default(player)
  spica_balance  Int           @default(0)
  xp             Int           @default(0)
  level          Int           @default(1)
  onlineStatus   String        @default("offline")
  currentZoneId  String?
  lastSeenAt     DateTime?
  emailVerified  Boolean       @default(false)
  verificationToken String?
  resetToken     String?
  resetExpiresAt DateTime?
  membership     String        @default("Starter")
  favoriteZones  String[]      @default([])
  staffZoneId    String?
  createdAt      DateTime      @default(now())
  zones          Zone[]        @relation("ZoneOwner")
  staffZone      Zone?         @relation("ZoneStaff", fields: [staffZoneId], references: [id])
  currentZone    Zone?         @relation("CurrentPlayerZone", fields: [currentZoneId], references: [id])
  sessions       Session[]     @relation("PlayerSessions")
  transactions   Transaction[]
  withdrawals    Withdrawal[]
  auditLogs      AuditLog[]
  achievements   UserAchievement[]
  notifications  PlayerNotification[]
  activities     EcosystemActivity[]
  friendshipsSent Friendship[] @relation("FriendshipsSent")
  friendshipsReceived Friendship[] @relation("FriendshipsReceived")
}

model Zone {
  id          String       @id @default(cuid())
  name        String
  city        String
  ownerId     String
  branding    Json         @default("{}")
  pricing     Json         @default("{}")
  status      ZoneStatus   @default(pending)
  featured    Boolean      @default(false)
  owner       User         @relation("ZoneOwner", fields: [ownerId], references: [id])
  pcs         PC[]
  sessions    Session[]
  settlements Settlement[]
  staff       User[]       @relation("ZoneStaff")
  currentPlayers User[]    @relation("CurrentPlayerZone")
  activities  EcosystemActivity[]
  createdAt   DateTime     @default(now())
}

model PC {
  id            String      @id @default(cuid())
  name          String
  zoneId        String
  authToken     String?
  status        PCStatus    @default(available)
  category      PCCategory  @default(standard)
  ratePerHour   Int         @default(100)
  maintenanceMode Boolean   @default(false)
  lastHeartbeat DateTime?
  ipAddress     String?
  machineName   String?
  zone          Zone        @relation(fields: [zoneId], references: [id])
  sessions      Session[]
  client        PCClient?

  @@unique([zoneId, name])
}

model Session {
  id              String        @id @default(cuid())
  playerId        String
  zoneId          String
  pcId            String
  startTime       DateTime      @default(now())
  durationSeconds Int
  status          SessionStatus @default(active)
  gross           Int
  completedAt     DateTime?
  player          User          @relation("PlayerSessions", fields: [playerId], references: [id])
  zone            Zone          @relation(fields: [zoneId], references: [id])
  pc              PC            @relation(fields: [pcId], references: [id])
  settlement      Settlement?
  createdAt       DateTime      @default(now())
}

model Transaction {
  id        String          @id @default(cuid())
  userId    String
  type      TransactionType
  amount    Int
  createdAt DateTime        @default(now())
  user      User            @relation(fields: [userId], references: [id])
}

model Settlement {
  id         String   @id @default(cuid())
  zoneId     String
  sessionId  String?  @unique
  gross      Int
  commission Int
  net        Int
  status     SettlementStatus @default(pending)
  payoutMethod String?
  approvedAt DateTime?
  paidAt     DateTime?
  createdAt  DateTime @default(now())
  zone       Zone     @relation(fields: [zoneId], references: [id])
  session    Session? @relation(fields: [sessionId], references: [id])
}

model Withdrawal {
  id        String           @id @default(cuid())
  userId    String
  amount    Int
  fee       Int
  status    WithdrawalStatus @default(pending)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])
}

model PCClient {
  id               String   @id @default(cuid())
  pcId             String   @unique
  authToken        String   @unique
  lastSeen         DateTime?
  installedVersion String?
  trustedFingerprint String?
  pairedAt         DateTime?
  pc               PC       @relation(fields: [pcId], references: [id])
}

model AuditLog {
  id        String      @id @default(cuid())
  actorId   String?
  action    AuditAction
  metadata  Json?
  createdAt DateTime    @default(now())
  actor     User?       @relation(fields: [actorId], references: [id])
}

model Achievement {
  id          String   @id
  name        String
  description String
  icon        String
  xpReward    Int      @default(100)
  createdAt   DateTime @default(now())
  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id])
  achievement   Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
}

model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(pending)
  createdAt   DateTime         @default(now())
  requester   User             @relation("FriendshipsSent", fields: [requesterId], references: [id])
  addressee   User             @relation("FriendshipsReceived", fields: [addresseeId], references: [id])

  @@unique([requesterId, addresseeId])
}

model PlayerNotification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(system)
  title     String
  message   String
  read      Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])
}

model EcosystemActivity {
  id        String   @id @default(cuid())
  userId    String?
  zoneId    String?
  type      String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
  zone      Zone?    @relation(fields: [zoneId], references: [id])
}

model ZoneListingRequest {
  id                  String               @id @default(cuid())
  ownerName           String
  email               String
  phone               String
  zoneName            String
  city                String
  pcCount             Int
  currentPricingModel String
  message             String?
  status              ListingRequestStatus @default(pending)
  createdAt           DateTime             @default(now())
}

model PCPairingRequest {
  id               String               @id @default(cuid())
  zoneId           String?
  machineName      String
  ipAddress        String?
  fingerprint      String
  installedVersion String?
  pairingCode      String               @unique
  status           PairingRequestStatus @default(pending)
  requestedPcName  String?
  assignedPcName   String?
  assignedPcId     String?
  assignedToken    String?
  category         PCCategory           @default(standard)
  ratePerHour      Int                  @default(100)
  rejectedReason   String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}
